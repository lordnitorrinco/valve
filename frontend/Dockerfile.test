# Test runner container for Vitest frontend tests.
# Uses Node.js with jsdom to simulate a browser environment.

FROM node:22-alpine

WORKDIR /app

# Install test dependencies (Vitest + jsdom)
COPY package.json vitest.config.js ./
RUN npm install --no-audit --no-fund

# Copy source and test files
COPY src/ src/
COPY tests/ tests/

# Run tests by default
CMD ["npx", "vitest", "run"]
