DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_NAME=evolve
DB_USER=evolve
DB_PASSWORD=CHANGE_ME_strong_app_password

API_PORT=80
FRONTEND_PORT=8080
PMA_PORT=8081

# Security
ENCRYPTION_KEY=CHANGE_ME_random_32_character_key
CSRF_SECRET=CHANGE_ME_random_csrf_secret_key
ALLOWED_ORIGIN=http://localhost:8080
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MINUTES=5

# Webhook forwarding (set to true to forward submissions to external endpoint)
FORWARD_WEBHOOK_ENABLED=true
FORWARD_WEBHOOK_URL=https://n8n.cloud.evolveacademy.es/webhook/prueba-tecnica-fullstack
